pipeline {
    agent any

    parameters {
        string(name: 'DEPLOY_SHA', defaultValue: '', description: 'Redeploy a prebuilt sha image without rebuilding (rollback via bin/deploy). Empty = build the checked-out commit.')
    }

    environment {
        APP_NAME = 'cptsd-main'
        DEPLOY_PATH = '/opt/main'
        DOMAIN = 'cptsd.in'
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    sh 'rm -rf * .* || true'
                }
                checkout scm
            }
        }

        stage('Resolve version') {
            steps {
                script {
                    def requested = (params.DEPLOY_SHA ?: '').trim()
                    env.SHA = requested ? requested : env.GIT_COMMIT.take(7)
                    env.REDEPLOY = requested ? 'true' : 'false'
                    // Validate before SHA ever reaches a shell — a hex-only value
                    // cannot inject commands regardless of how it is expanded.
                    if (!(env.SHA ==~ /^[a-f0-9]{7,40}$/)) {
                        error("DEPLOY_SHA must be a 7-40 char hex git sha (got '${env.SHA}')")
                    }
                    echo "Version: main:${env.SHA} (redeploy=${env.REDEPLOY})"
                }
            }
        }

        stage('Build') {
            when { expression { env.REDEPLOY == 'false' } }
            steps {
                dir('apps/main') {
                    script {
                        echo "Building ${APP_NAME} image main:${env.SHA}..."
                        sh """
                            echo "MONGODB_URI: \${MONGODB_URI:+SET}"

                            # Build with --network=host so the Next.js build can reach
                            # Google Fonts (required by next/font/google in layout.tsx).
                            # Tag by immutable short-sha AND latest (the sha enables rollback).
                            DOCKER_BUILDKIT=0 docker build \\
                                --network=host \\
                                --build-arg MONGODB_URI=\${MONGODB_URI:-} \\
                                -f Dockerfile \\
                                -t "main:\${SHA}" \\
                                -t main:latest \\
                                ..
                        """
                    }
                }
            }
        }

        stage('Verify image') {
            when { expression { env.REDEPLOY == 'true' } }
            steps {
                sh """
                    if ! docker image inspect "main:\${SHA}" >/dev/null 2>&1; then
                        echo "Image main:\${SHA} not found on this host — cannot redeploy a pruned artifact."
                        echo "Re-run a normal build of that commit, or pick a sha whose image still exists."
                        exit 1
                    fi
                    echo "Reusing prebuilt image main:\${SHA}"
                """
            }
        }

        stage('Test') {
            when { expression { env.REDEPLOY == 'false' } }
            steps {
                // BLOCKING: run the unit's Nx tests in a node container against the
                // checked-out workspace (devDeps present, independent of the prod image).
                // A test failure fails the build before Deploy.
                sh '''
                    docker run --rm --volumes-from jenkins -w "$PWD" node:20-bookworm-slim bash -lc '
                        corepack enable &&
                        corepack prepare pnpm@9 --activate &&
                        pnpm install --frozen-lockfile &&
                        pnpm exec nx test main
                    '
                '''
            }
        }

        stage('Deploy') {
            steps {
                script {
                    echo "Deploying ${APP_NAME} (main:${env.SHA}) to ${DOMAIN}..."
                    sh """
                        # Write env file for production container
                        mkdir -p ${DEPLOY_PATH}
                        printf 'MONGODB_URI=%s\\n' "\${MONGODB_URI:-}" > ${DEPLOY_PATH}/.env

                        # Stop any existing container(s) on port 3002
                        docker rm -f main-app 2>/dev/null || true
                        # Also remove any other container that might hold port 3002
                        docker ps -q --filter publish=3002 | xargs -r docker rm -f || true
                        # Kill any non-Docker process on port 3002 (e.g. dev server)
                        fuser -k 3002/tcp 2>/dev/null || true
                        sleep 2

                        # Start production container from the resolved sha image
                        docker run -d \\
                            --name main-app \\
                            --network cptsd_net \\
                            -p 3002:3002 \\
                            -e NODE_ENV=production \\
                            -e NEXT_TELEMETRY_DISABLED=1 \\
                            -e MONGODB_URI=\${MONGODB_URI:-} \\
                            --read-only \\
                            --tmpfs /tmp \\
                            --tmpfs /app/.next/cache \\
                            --restart always \\
                            "main:\${SHA}"

                        sleep 20
                        docker ps --filter name=main-app
                    """
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    echo "Performing health check for ${DOMAIN}..."
                    sh """
                        sleep 10
                        # Blocking health gate: retry until 200 or fail the build
                        ok=0
                        for i in \$(seq 1 30); do
                            if curl -fsS http://localhost:3002/ >/dev/null; then
                                ok=1
                                break
                            fi
                            sleep 2
                        done
                        if [ "\$ok" -ne 1 ]; then
                            echo "Health check failed after retries"
                            exit 1
                        fi
                        echo "Health check passed"
                    """
                }
            }
        }
    }

    post {
        success {
            echo "${APP_NAME} deployment to ${DOMAIN} successful! (main:${env.SHA})"
        }
        failure {
            echo "${APP_NAME} deployment to ${DOMAIN} failed!"
            sh 'docker logs main-app --tail=50 2>/dev/null || true'
        }
        always {
            cleanWs()
        }
    }
}
