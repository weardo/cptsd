pipeline {
    agent any

    parameters {
        string(name: 'DEPLOY_SHA', defaultValue: '', description: 'Redeploy a prebuilt sha image without rebuilding (rollback via bin/deploy). Empty = build the checked-out commit.')
    }

    environment {
        APP_NAME = 'cptsd-blog-public'
        DEPLOY_PATH = '/opt/blog'
        DOCKER_COMPOSE_FILE = 'docker-compose.yml'
        DOCKER_COMPOSE_PROD_FILE = 'docker-compose.prod.yml'
        DOMAIN = 'blog.cptsd.in'
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    // Clean workspace
                    sh 'rm -rf * .* || true'
                }
                checkout scm
            }
        }

        stage('Resolve version') {
            steps {
                script {
                    def requested = (params.DEPLOY_SHA ?: '').trim()
                    env.SHA = requested ? requested : env.GIT_COMMIT.take(7)
                    env.REDEPLOY = requested ? 'true' : 'false'
                    echo "Version: blog:${env.SHA} (redeploy=${env.REDEPLOY})"
                }
            }
        }

        stage('Build') {
            when { expression { env.REDEPLOY == 'false' } }
            steps {
                dir('apps/blog') {
                    script {
                        echo "Building ${APP_NAME} image blog:${env.SHA}..."
                        sh """
                            export MONGODB_URI=\${MONGODB_URI:-}

                            # Build the app image (compose tags it blog:latest via the image: field),
                            # then tag the immutable short-sha for pinning/rollback.
                            docker-compose -f ${DOCKER_COMPOSE_FILE} build app
                            docker tag blog:latest blog:\${SHA}
                        """
                    }
                }
            }
        }

        stage('Verify image') {
            when { expression { env.REDEPLOY == 'true' } }
            steps {
                sh """
                    if ! docker image inspect blog:\${SHA} >/dev/null 2>&1; then
                        echo "Image blog:\${SHA} not found on this host — cannot redeploy a pruned artifact."
                        echo "Re-run a normal build of that commit, or pick a sha whose image still exists."
                        exit 1
                    fi
                    echo "Reusing prebuilt image blog:\${SHA}"
                """
            }
        }

        stage('Test') {
            when { expression { env.REDEPLOY == 'false' } }
            steps {
                dir('apps/blog') {
                    script {
                        echo 'Running tests...'
                        // Single-quoted: shell expands $SHA / $DOCKER_COMPOSE_FILE from the Jenkins env.
                        sh 'BLOG_IMAGE=blog:${SHA} docker-compose -f ${DOCKER_COMPOSE_FILE} run --rm app npm test || echo "Tests failed but continuing..."'
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    echo "Deploying ${APP_NAME} (blog:${env.SHA}) to ${DOMAIN}..."
                    sh """
                        # Copy files to deployment directory
                        mkdir -p ${DEPLOY_PATH}
                        cp -r apps/blog/* ${DEPLOY_PATH}/

                        cd ${DEPLOY_PATH}

                        if [ -d .git ]; then
                            git pull origin main || git pull origin master || true
                        fi

                        export MONGODB_URI=\${MONGODB_URI:-}

                        # Pin the exact artifact for this deploy (rollback-safe).
                        export BLOG_IMAGE=blog:\${SHA}

                        echo "Stopping existing containers..."
                        docker-compose -f ${DOCKER_COMPOSE_FILE} -f ${DOCKER_COMPOSE_PROD_FILE} down --remove-orphans || true

                        echo "Removing any orphaned containers..."
                        docker rm -f blog-app-1 2>/dev/null || true

                        # Start services using the pinned prebuilt image (no rebuild here).
                        docker-compose -f ${DOCKER_COMPOSE_FILE} -f ${DOCKER_COMPOSE_PROD_FILE} up -d --no-build

                        sleep 30
                        docker-compose -f ${DOCKER_COMPOSE_FILE} -f ${DOCKER_COMPOSE_PROD_FILE} ps
                    """
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    echo "Performing health check for ${DOMAIN}..."
                    sh """
                        sleep 10
                        # Blocking health gate: retry until 200 or fail the build
                        ok=0
                        for i in \$(seq 1 30); do
                            if curl -fsS http://localhost:3001/ >/dev/null; then
                                ok=1
                                break
                            fi
                            sleep 2
                        done
                        if [ "\$ok" -ne 1 ]; then
                            echo "Health check failed after retries"
                            exit 1
                        fi
                        echo "Health check passed"
                    """
                }
            }
        }
    }

    post {
        success {
            echo "${APP_NAME} deployment to ${DOMAIN} successful! (blog:${env.SHA})"
        }
        failure {
            echo "${APP_NAME} deployment to ${DOMAIN} failed!"
            sh 'docker-compose -f ${DEPLOY_PATH}/${DOCKER_COMPOSE_FILE} -f ${DEPLOY_PATH}/${DOCKER_COMPOSE_PROD_FILE} logs --tail=50'
        }
        always {
            cleanWs()
        }
    }
}
