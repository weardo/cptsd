pipeline {
    agent any

    parameters {
        string(name: 'DEPLOY_SHA', defaultValue: '', description: 'Redeploy a prebuilt sha image without rebuilding (rollback via bin/deploy). Empty = build the checked-out commit.')
    }

    environment {
        APP_NAME = 'cptsd-cms'
        DEPLOY_PATH = '/opt/cms'
        DOCKER_COMPOSE_FILE = 'docker-compose.yml'
        DOCKER_COMPOSE_PROD_FILE = 'docker-compose.prod.yml'
        DOMAIN = 'cms.cptsd.in'
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    // Clean workspace
                    sh 'rm -rf * .* || true'
                }
                checkout scm
            }
        }

        stage('Resolve version') {
            steps {
                script {
                    def requested = (params.DEPLOY_SHA ?: '').trim()
                    env.SHA = requested ? requested : env.GIT_COMMIT.take(7)
                    env.REDEPLOY = requested ? 'true' : 'false'
                    echo "Version: cms:${env.SHA} (redeploy=${env.REDEPLOY})"
                }
            }
        }

        stage('Build') {
            when { expression { env.REDEPLOY == 'false' } }
            steps {
                dir('apps/cms') {
                    script {
                        echo "Building ${APP_NAME} image cms:${env.SHA}..."
                        sh """
                            # Jenkins Global Properties are already env vars; export for docker-compose build.
                            export OPENAI_API_KEY=\${OPENAI_API_KEY:-}
                            export MONGODB_URI=\${MONGODB_URI:-}
                            export S3_ENDPOINT=\${S3_ENDPOINT:-}
                            export S3_ACCESS_KEY_ID=\${S3_ACCESS_KEY_ID:-}
                            export S3_SECRET_ACCESS_KEY=\${S3_SECRET_ACCESS_KEY:-}
                            export S3_BUCKET_NAME=\${S3_BUCKET_NAME:-}
                            export ADMIN_EMAIL=\${ADMIN_EMAIL:-}
                            export ADMIN_PASSWORD=\${ADMIN_PASSWORD:-}
                            export NEXTAUTH_URL=\${NEXTAUTH_URL:-}
                            export NEXTAUTH_SECRET=\${NEXTAUTH_SECRET:-}

                            echo "Environment variables check (from Jenkins Global Properties):"
                            echo "  OPENAI_API_KEY: \${OPENAI_API_KEY:+SET (hidden)}"
                            echo "  MONGODB_URI: \${MONGODB_URI:+SET}"
                            echo "  S3_ACCESS_KEY_ID: \${S3_ACCESS_KEY_ID:+SET (hidden)}"
                            echo "  ADMIN_EMAIL: \${ADMIN_EMAIL:+SET}"
                            echo "  NEXTAUTH_SECRET: \${NEXTAUTH_SECRET:+SET (hidden)}"

                            # Build the app image (compose tags it cms:latest via the image: field),
                            # then tag the immutable short-sha for pinning/rollback.
                            docker-compose -f ${DOCKER_COMPOSE_FILE} build app
                            docker tag cms:latest cms:\${SHA}
                        """
                    }
                }
            }
        }

        stage('Verify image') {
            when { expression { env.REDEPLOY == 'true' } }
            steps {
                sh """
                    if ! docker image inspect cms:\${SHA} >/dev/null 2>&1; then
                        echo "Image cms:\${SHA} not found on this host — cannot redeploy a pruned artifact."
                        echo "Re-run a normal build of that commit, or pick a sha whose image still exists."
                        exit 1
                    fi
                    echo "Reusing prebuilt image cms:\${SHA}"
                """
            }
        }

        stage('Test') {
            when { expression { env.REDEPLOY == 'false' } }
            steps {
                dir('apps/cms') {
                    script {
                        echo 'Running tests...'
                        // Single-quoted: shell expands $SHA / $DOCKER_COMPOSE_FILE from the Jenkins env.
                        sh 'CMS_IMAGE=cms:${SHA} docker-compose -f ${DOCKER_COMPOSE_FILE} run --rm app npm test || echo "Tests failed but continuing..."'
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    echo "Deploying ${APP_NAME} (cms:${env.SHA}) to ${DOMAIN}..."
                    sh """
                        # Copy files to deployment directory
                        mkdir -p ${DEPLOY_PATH}
                        cp -r apps/cms/* ${DEPLOY_PATH}/

                        cd ${DEPLOY_PATH}

                        if [ -d .git ]; then
                            git pull origin main || git pull origin master || true
                        fi

                        # Jenkins Global Properties are already env vars; export for docker-compose.
                        export OPENAI_API_KEY=\${OPENAI_API_KEY:-}
                        export MONGODB_URI=\${MONGODB_URI:-}
                        export S3_ENDPOINT=\${S3_ENDPOINT:-}
                        export S3_ACCESS_KEY_ID=\${S3_ACCESS_KEY_ID:-}
                        export S3_SECRET_ACCESS_KEY=\${S3_SECRET_ACCESS_KEY:-}
                        export S3_BUCKET_NAME=\${S3_BUCKET_NAME:-}
                        export ADMIN_EMAIL=\${ADMIN_EMAIL:-}
                        export ADMIN_PASSWORD=\${ADMIN_PASSWORD:-}
                        export NEXTAUTH_URL=\${NEXTAUTH_URL:-}
                        export NEXTAUTH_SECRET=\${NEXTAUTH_SECRET:-}

                        # Pin the exact artifact for this deploy (rollback-safe).
                        export CMS_IMAGE=cms:\${SHA}

                        echo "Stopping existing containers..."
                        docker-compose -f ${DOCKER_COMPOSE_FILE} -f ${DOCKER_COMPOSE_PROD_FILE} down --remove-orphans || true

                        echo "Removing any orphaned containers..."
                        docker rm -f cms-app-1 cms-minio-1 cms-mongodb-1 2>/dev/null || true

                        # Start services using the pinned prebuilt image (no rebuild here).
                        docker-compose -f ${DOCKER_COMPOSE_FILE} -f ${DOCKER_COMPOSE_PROD_FILE} up -d --no-build

                        sleep 30
                        docker-compose -f ${DOCKER_COMPOSE_FILE} -f ${DOCKER_COMPOSE_PROD_FILE} ps
                    """
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    echo "Performing health check for ${DOMAIN}..."
                    sh """
                        sleep 10
                        # Blocking health gate: retry until 200 or fail the build
                        ok=0
                        for i in \$(seq 1 30); do
                            if curl -fsS http://localhost:3000/api/init >/dev/null; then
                                ok=1
                                break
                            fi
                            sleep 2
                        done
                        if [ "\$ok" -ne 1 ]; then
                            echo "Health check failed after retries"
                            exit 1
                        fi
                        echo "Health check passed"
                    """
                }
            }
        }
    }

    post {
        success {
            echo "${APP_NAME} deployment to ${DOMAIN} successful! (cms:${env.SHA})"
        }
        failure {
            echo "${APP_NAME} deployment to ${DOMAIN} failed!"
            sh 'docker-compose -f ${DEPLOY_PATH}/${DOCKER_COMPOSE_FILE} -f ${DEPLOY_PATH}/${DOCKER_COMPOSE_PROD_FILE} logs --tail=50'
        }
        always {
            cleanWs()
        }
    }
}
