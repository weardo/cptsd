{
  "name": "journal",
  "root": "apps/journal",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "next build", "cwd": "apps/journal" },
      "outputs": ["{projectRoot}/.next"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": { "command": "next dev -p 3003", "cwd": "apps/journal" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "jest", "cwd": "apps/journal" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint .", "cwd": "apps/journal" }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit", "cwd": "apps/journal" }
    }
  }
}
