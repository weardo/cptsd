pipeline {
    agent any

    environment {
        APP_NAME = 'cptsd-main'
        DEPLOY_PATH = '/opt/cptsd-main'
        DOMAIN = 'cptsd.in'
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    sh 'rm -rf * .* || true'
                }
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir('cptsd-main') {
                    script {
                        echo "Building ${APP_NAME} Docker image..."
                        sh """
                            echo "MONGODB_URI: \${MONGODB_URI:+SET}"

                            # Build with --network=host so the Next.js build can reach
                            # Google Fonts (required by next/font/google in layout.tsx)
                            DOCKER_BUILDKIT=0 docker build \\
                                --network=host \\
                                --build-arg MONGODB_URI=\${MONGODB_URI:-} \\
                                -f Dockerfile \\
                                -t cptsd-main:latest \\
                                ..
                        """
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    echo "Deploying ${APP_NAME} to ${DOMAIN}..."
                    sh """
                        # Write env file for production container
                        mkdir -p ${DEPLOY_PATH}
                        printf 'MONGODB_URI=%s\\n' "\${MONGODB_URI:-}" > ${DEPLOY_PATH}/.env

                        # Stop any existing container
                        docker rm -f cptsd-main-app 2>/dev/null || true

                        # Start production container
                        docker run -d \\
                            --name cptsd-main-app \\
                            --network cptsd-cms_app-network \\
                            -p 3002:3002 \\
                            -e NODE_ENV=production \\
                            -e NEXT_TELEMETRY_DISABLED=1 \\
                            -e MONGODB_URI=\${MONGODB_URI:-} \\
                            --read-only \\
                            --tmpfs /tmp \\
                            --tmpfs /app/.next/cache \\
                            --restart always \\
                            cptsd-main:latest

                        sleep 20
                        docker ps --filter name=cptsd-main-app
                    """
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    echo "Performing health check for ${DOMAIN}..."
                    sh """
                        sleep 10
                        curl -f http://localhost:3002 || echo "Health check failed"
                    """
                }
            }
        }
    }

    post {
        success {
            echo "${APP_NAME} deployment to ${DOMAIN} successful!"
        }
        failure {
            echo "${APP_NAME} deployment to ${DOMAIN} failed!"
            sh 'docker logs cptsd-main-app --tail=50 2>/dev/null || true'
        }
        always {
            cleanWs()
        }
    }
}
